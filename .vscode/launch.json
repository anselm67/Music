    "version": "0.2.0",
    "configurations": [
        // kern cli
        {
            "name": "kern midi",
            "type": "debugpy",
            "request": "launch",
            "module": "cli.kern",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "midi",
                "/home/anselm/datasets/kern-sheet/haydn/keyboard/uesonatas/sonata45-3a.krn"
            ]
        },
        // pdmx cli
        {
            "name": "pdmx show",
            "type": "debugpy",
            "request": "launch",
            "module": "cli.pdmx",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "show",
                "./mxl/1/11/QmbbFXoGYxR8JLdAwi9U77pGVWxgkStWZBEyUqC9gQtjWH.mxl"
            ]
        },
        {
            "name": "pdmx query",
            "type": "debugpy",
            "request": "launch",
            "module": "cli.pdmx",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "query",
                "-c",
                "mxl",
                "index == index",
                "-s",
                "pages.*.staff_count < 16"
            ]
        },
        {
            "name": "pdmx make",
            "type": "debugpy",
            "request": "launch",
            "module": "cli.pdmx",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "make",
            ]
        },
        {
            "name": "pdmx stats",
            "type": "debugpy",
            "request": "launch",
            "module": "cli.pdmx",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "--csv",
                "Staff16.csv",
                "stats",
            ]
        },
        // staffer cli.
        {
            "name": "staffer show",
            "type": "debugpy",
            "request": "launch",
            "module": "cli.staffer",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "show",
            ]
        },
        {
            "name": "staffer stats",
            "type": "debugpy",
            "request": "launch",
            "module": "cli.staffer",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "stats",
            ]
        },
        {
            "name": "staffer train",
            "type": "debugpy",
            "request": "launch",
            "module": "cli.staffer",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "train",
                "testing"
            ]
        },
        {
            "name": "staffer predict",
            "type": "debugpy",
            "request": "launch",
            "module": "cli.staffer",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "predict",
                "epoch4x2",
                "/home/anselm/datasets/PDMX/png/1/11/Qmbb98pzePiuBgWkaiftdheCqa4PVer6PMo3nsspnfz8ub.png"
            ]
        }
    ]
}